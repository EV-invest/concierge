# Copy to `.env` and adjust. Loaded by dotenvy in development.
# `nix run .#db` boots a local Postgres matching this URL (trust auth, no password).
DATABASE_URL=postgres://postgres@localhost:5432/ev_concierge
# Max connections for the request-serving Postgres pool. Defaults to 10 when unset.
DB_MAX_CONNECTIONS=10
# gRPC listener for the modular-monolith surface (auth + directory + notification +
# log + health). Loopback by default — widen only behind network segmentation.
CONCIERGE_BIND=127.0.0.1:50061
RUST_LOG=info,concierge=debug,evconcierge_auth=debug

# Sentry error tracking via ev::error_monitoring (optional — disabled when unset).
SENTRY_DSN=
APP_ENV=development

# PostHog product analytics via ev::analytics (optional — capture is a no-op when
# POSTHOG_KEY is unset). POSTHOG_HOST defaults to https://us.i.posthog.com.
POSTHOG_KEY=
POSTHOG_HOST=
