# Copy to `.env` and adjust. Loaded by dotenvy in development.
# `nix run .#db` boots a local Postgres matching this URL (trust auth, no password).
DATABASE_URL=postgres://postgres@localhost:5432/ev_concierge
# Max connections for the request-serving Postgres pool. Defaults to 10 when unset.
DB_MAX_CONNECTIONS=10
# Canonical user ids allowed to call the admin directory RPCs (RevokeTokens,
# DisableUser). Comma-separated; empty ⇒ no admins (every admin RPC is denied).
ADMIN_SUBJECTS=
# gRPC listener for the modular-monolith surface (auth + directory + notification +
# log + health). Loopback by default — widen only behind network segmentation.
CONCIERGE_BIND=127.0.0.1:50061

# Cross-plane bridge (identity → money). Shared bearer token the banking money plane
# presents on UserEvents.PullUserLifecycle (banking PULLS the user_outbox; concierge
# never calls banking). Must match BRIDGE_SERVICE_TOKEN on the banking side. Unset ⇒
# the bridge is not served (every pull is rejected). Graduate to mTLS/SPIFFE at scale.
BRIDGE_SERVICE_TOKEN=
RUST_LOG=info,concierge=debug,evconcierge_auth=debug

# Central auth only: refresh-token rotation / revocation store. NOT per-service —
# services verify access tokens statelessly against cached JWKS. Set it to back the
# refresh store with Redis (shared across replicas, durable across restarts); leave
# unset to keep the in-process store (single-instance/dev — no-op-until-configured,
# so local/CI is unaffected).
REDIS_URL=

# ── Auth service (token issuance) ─────────────────────────────────────────────
# All optional: with no signing key the auth service runs inert (mints nothing) and
# the inbound verifier fails closed, so the plane still boots locally. To enable,
# generate an Ed25519 keypair:
#   openssl genpkey -algorithm ed25519 -out auth_ed25519.pem
# then set the PEM, a kid, and the matching public JWKS (a {"keys":[{OKP…}]} JSON).
AUTH_SIGNING_KEY_PEM=
AUTH_SIGNING_KID=
AUTH_JWKS_JSON=
# Issuer + audiences (defaults shown). Client access tokens carry the client aud;
# service tokens the service aud — distinct, so the two JWT directions stay apart.
# These MUST carry this plane's identity ("concierge"); a banking value is refused at
# boot (cross-plane footgun). (Refresh tokens are opaque rotated handles, not JWTs.)
AUTH_ISSUER=https://auth.concierge.ev
AUTH_CLIENT_AUDIENCE=concierge
AUTH_SERVICE_AUDIENCE=concierge-services
# Token TTLs in seconds (defaults: 15 min access, 30 d refresh, 5 min service).
AUTH_ACCESS_TTL_SECS=900
AUTH_REFRESH_TTL_SECS=2592000
AUTH_SERVICE_TTL_SECS=300
# Refresh-family lifetime bounds: absolute cap (default 90 d) and idle timeout (0 = off).
AUTH_MAX_SESSION_SECS=7776000
AUTH_IDLE_TIMEOUT_SECS=0
# Where the inbound verifier dials the Jwks RPC. Defaults to this plane's own bind
# address (it serves its own JWKS in-process); override for a split deployment.
AUTH_JWKS_GRPC_ENDPOINT=http://127.0.0.1:50061

# Google OAuth2 confidential client (the BFF starts the redirect; the auth service
# does the code→token exchange). Empty ⇒ the Exchange route is disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry error tracking via ev::error_monitoring (optional — disabled when unset).
SENTRY_DSN=
APP_ENV=development

# PostHog product analytics via ev::analytics (optional — capture is a no-op when
# POSTHOG_KEY is unset). POSTHOG_HOST defaults to https://us.i.posthog.com.
POSTHOG_KEY=
POSTHOG_HOST=
